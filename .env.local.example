# Notion Integration Token
# Obtén uno en: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la Base de Datos de Propuestas en Notion
# Está en la URL de tu BD: notion.so/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx?v=...
NOTION_PROPUESTAS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la Base de Datos de Cotizaciones (se crea una vez y se anota aquí)
# La primera vez déjalo vacío; después de crear la BD, pega el ID aquí
NOTION_COTIZACIONES_DB_ID=
